        <bpmn:flowNodeRef>Gateway_1or6buk</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Gateway_12v3tqe</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Gateway_11m8jdg</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Activity_1mdywsv</bpmn:flowNodeRef>
      </bpmn:lane>
    </bpmn:laneSet>
    <bpmn:sequenceFlow id="Flow_0b2zry9" sourceRef="Activity_1hhodun" targetRef="Activity_13bkodr" />
    <bpmn:sequenceFlow id="Flow_0443x7f" sourceRef="Activity_13bkodr" targetRef="Gateway_1v4dp0x" />
    <bpmn:sequenceFlow id="Flow_12fseu5" name="No" sourceRef="Gateway_1v4dp0x" targetRef="Event_1ns8djw">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">=promise = false</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="Flow_0kjxhqv" name="Yes" sourceRef="Gateway_1v4dp0x" targetRef="Activity_08qeh6t">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">=promise = true</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="Flow_1auv1xt" sourceRef="Activity_08qeh6t" targetRef="Gateway_0jfrlfh" />
    <bpmn:sequenceFlow id="Flow_0c7c7tg" name="Generated&#10;Energy or Consumed&#10;Energy" sourceRef="Gateway_0jfrlfh" targetRef="Task_FetchProsumers">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">=list contains(selectedMetrics, "Generated Energy") or list contains(selectedMetrics, "Consumed Energy")</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="Flow_1goqek8" name="Energy&#10;Discharged or Average SoC" sourceRef="Gateway_0jfrlfh" targetRef="Activity_1mdywsv">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">=list contains(selectedMetrics, "Energy Discharged") or list contains(selectedMetrics, "Average SoC")</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:startEvent id="StartEvent_Timer" name="Every 30 Minutes">
      <bpmn:outgoing>Flow_1q44axk</bpmn:outgoing>
      <bpmn:timerEventDefinition id="TED_Timer">
        <bpmn:timeCycle xsi:type="bpmn:tFormalExpression">R/PT30M</bpmn:timeCycle>
      </bpmn:timerEventDefinition>
    </bpmn:startEvent>
    <bpmn:userTask id="Activity_1hhodun" name="Decide What to Anaiyse">
      <bpmn:extensionElements>
        <zeebe:userTask />
        <zeebe:formDefinition formId="Form_Select_EnergyAnalytics" />
        <zeebe:assignmentDefinition assignee="demo" />
