      <bpmn:incoming>Flow_1q44axk</bpmn:incoming>
      <bpmn:outgoing>Flow_0b2zry9</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:endEvent id="Event_1ns8djw" name="Energy Analytics not possible">
