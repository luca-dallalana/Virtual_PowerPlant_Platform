    <bpmn:serviceTask id="Activity_10bhmpn" name="Emit Energy Analytics" zeebe:modelerTemplate="io.camunda.connectors.HttpJson.v2" zeebe:modelerTemplateVersion="13" zeebe:modelerTemplateIcon="data:image/svg+xml;base64,">
