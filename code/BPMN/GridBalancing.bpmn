    <bpmn:serviceTask id="Activity_16t05qa" name="Retrieve GridCell neighbours" zeebe:modelerTemplate="io.camunda.connectors.HttpJson.v2" zeebe:modelerTemplateVersion="13" zeebe:modelerTemplateIcon="data:image/svg+xml;base64,">
