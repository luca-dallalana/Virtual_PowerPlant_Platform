      <bpmn:incoming>Flow_1xm4l2t</bpmn:incoming>
      <bpmn:outgoing>Flow_1oixawr</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:scriptTask id="Activity_0rx3oti" name="Identify Surplus Grid Cells">
      <bpmn:extensionElements>
        <zeebe:script expression="=neighbourMetrics[headroom &#62; 0].gridCellId" resultVariable="surplusGridCells" />
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_1oixawr</bpmn:incoming>
      <bpmn:outgoing>Flow_0p5pyrl</bpmn:outgoing>
    </bpmn:scriptTask>
    <bpmn:scriptTask id="Activity_0rpaydt" name="Categorize Assets for Evaluation">
      <bpmn:extensionElements>
        <zeebe:script expression="=concatenate(&#10;  for t in GridCellTelemetry return {&#10;    asset_id: t.asset_id,&#10;    asset_type: t.asset_type,&#10;    grid_cell_id: t.grid_cell_id,&#10;    cell_context: &#34;STRESSED&#34;,&#10;    soc_percent: if t.asset_type = &#34;BATTERY&#34; then t.State_of_Charge else null,&#10;    is_charging: if t.asset_type = &#34;BATTERY&#34;&#10;                 then (if t.Current_Output != null then t.Current_Output &#60; 0 else false)&#10;                 else if t.asset_type = &#34;EV_CHARGER&#34;&#10;                 then (if t.Charging_Rate != null then t.Charging_Rate &#62; 0 else false)&#10;                 else false&#10;  },&#10;  for t in neighboursGridCellTelemetry[grid_cell_id in surplusGridCells] return {&#10;    asset_id: t.asset_id,&#10;    asset_type: t.asset_type,&#10;    grid_cell_id: t.grid_cell_id,&#10;    cell_context: &#34;SURPLUS&#34;,&#10;    soc_percent: if t.asset_type = &#34;BATTERY&#34; then t.State_of_Charge else null,&#10;    is_charging: if t.asset_type = &#34;BATTERY&#34;&#10;                 then (if t.Current_Output != null then t.Current_Output &#60; 0 else false)&#10;                 else if t.asset_type = &#34;EV_CHARGER&#34;&#10;                 then (if t.Charging_Rate != null then t.Charging_Rate &#62; 0 else false)&#10;                 else false&#10;  }&#10;)" resultVariable="allAssetsToEvaluate" />
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_0p5pyrl</bpmn:incoming>
      <bpmn:outgoing>Flow_1io8cvg</bpmn:outgoing>
    </bpmn:scriptTask>
    <bpmn:businessRuleTask id="Activity_05ky24n" name="Grid Balancing Decision">
      <bpmn:extensionElements>
        <zeebe:calledDecision decisionId="Decision_GridBalancing" resultVariable="dmnResult" />
        <zeebe:ioMapping>
          <zeebe:input source="=currentAsset.asset_type" target="assetType" />
          <zeebe:input source="=currentAsset.cell_context" target="gridCellContext" />
          <zeebe:input source="=currentAsset.soc_percent" target="socPercent" />
          <zeebe:input source="=currentAsset.is_charging" target="isCharging" />
          <zeebe:output source="={ &#10;assetId: currentAsset.asset_id, &#10;action: dmnResult.action,&#10;from: currentAsset.grid_cell_id,&#10;to: selectedGridCell.gridCellId&#10;}" target="currentEvent" />
        </zeebe:ioMapping>
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_1io8cvg</bpmn:incoming>
      <bpmn:outgoing>Flow_1d4kgkw</bpmn:outgoing>
      <bpmn:multiInstanceLoopCharacteristics>
        <bpmn:extensionElements>
          <zeebe:loopCharacteristics inputCollection="=allAssetsToEvaluate" inputElement="currentAsset" outputCollection="evaluatedEvents" outputElement="=currentEvent" />
        </bpmn:extensionElements>
      </bpmn:multiInstanceLoopCharacteristics>
    </bpmn:businessRuleTask>
    <bpmn:scriptTask id="Activity_1h6cdx5" name="Filter out &#34;NO_ACTION&#34; Events">
      <bpmn:extensionElements>
        <zeebe:script expression="=evaluatedEvents[action != &#34;NO_ACTION&#34;]" resultVariable="GridBalancingList" />
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_1d4kgkw</bpmn:incoming>
      <bpmn:outgoing>Flow_0up0ctk</bpmn:outgoing>
    </bpmn:scriptTask>
    <bpmn:task id="Activity_1xasl7p" name="Declare neighbouring GridCell Analysis">
