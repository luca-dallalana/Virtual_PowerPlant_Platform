        <bpmn:flowNodeRef>Activity_0k6ynkp</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Activity_08kjrab</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Activity_1dvv2oq</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Activity_10t6jow</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Activity_1fwp0r4</bpmn:flowNodeRef>
      </bpmn:lane>
      <bpmn:lane id="Lane_Scheduler" name="Flexibility Forecasting Manager">
        <bpmn:flowNodeRef>Event_19ljhje</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Event_0azjwnq</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>GW_HasAssets</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Activity_0iwtr17</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Event_09dycxj</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>EndEvent_ForecastComplete</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Activity_1gqsmnq</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Gateway_0xdan8i</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Event_1akqo88</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>StartEvent_Timer</bpmn:flowNodeRef>
      </bpmn:lane>
    </bpmn:laneSet>
    <bpmn:sequenceFlow id="Flow_1c3laoh" sourceRef="StartEvent_Timer" targetRef="Activity_0iwtr17" />
    <bpmn:sequenceFlow id="Flow_1ebwveg" name="No" sourceRef="GW_HasAssets" targetRef="Event_0azjwnq">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">=decide = false</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="Flow_16ebd6x" sourceRef="Activity_0iwtr17" targetRef="GW_HasAssets" />
    <bpmn:sequenceFlow id="Flow_1w00wu5" name="No" sourceRef="Gateway_10xhc8a" targetRef="Event_19ljhje">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">=promise = false</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="Flow_1jp7h3m" name="Yes" sourceRef="GW_HasAssets" targetRef="Activity_1b1jk70">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">=decide = true</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:endEvent id="Event_19ljhje" name="Flexibility Forecasting not possible">
      <bpmn:incoming>Flow_1w00wu5</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:endEvent id="Event_0azjwnq" name="No Flexibility Forecasting analysis">
      <bpmn:incoming>Flow_1ebwveg</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:exclusiveGateway id="GW_HasAssets" name="Is Flexibility Forecasting to be evaluated ?">
      <bpmn:incoming>Flow_16ebd6x</bpmn:incoming>
      <bpmn:outgoing>Flow_1ebwveg</bpmn:outgoing>
      <bpmn:outgoing>Flow_1jp7h3m</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:userTask id="Activity_0iwtr17" name="Decide if Flexibility Forecasting will be evaluated">
      <bpmn:extensionElements>
        <zeebe:userTask />
        <zeebe:assignmentDefinition assignee="demo" />
        <zeebe:formDefinition formId="Form_Decide_FlexibilityForecasting" />
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_1c3laoh</bpmn:incoming>
      <bpmn:outgoing>Flow_16ebd6x</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:sequenceFlow id="Flow_1y0762k" name="No" sourceRef="Gateway_1wfxhep" targetRef="Event_09dycxj">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">=hasflexibilityLogs = false</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:endEvent id="Event_09dycxj" name="No Flexibility&#10;Event Logs">
      <bpmn:incoming>Flow_1y0762k</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:userTask id="Activity_1b1jk70" name="Verify if execute Flexibility Offer is possible">
      <bpmn:extensionElements>
        <zeebe:userTask />
        <zeebe:assignmentDefinition assignee="demo" />
        <zeebe:formDefinition formId="Form_Promise_FlexibilityForecasting" />
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_1jp7h3m</bpmn:incoming>
      <bpmn:outgoing>Flow_0a9e14a</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:exclusiveGateway id="Gateway_10xhc8a" name="Is Flexibility Forecasting possible?">
      <bpmn:incoming>Flow_0a9e14a</bpmn:incoming>
      <bpmn:outgoing>Flow_1w00wu5</bpmn:outgoing>
      <bpmn:outgoing>Flow_07ktx5n</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:task id="Activity_1obo2qh" name="Promise Flexibility Forecasting">
      <bpmn:incoming>Flow_07ktx5n</bpmn:incoming>
      <bpmn:outgoing>Flow_1y0y9l8</bpmn:outgoing>
    </bpmn:task>
    <bpmn:serviceTask id="Task_FetchFlexibilityLogs" name="Retrieve Flexibility&#10;Event Logs" zeebe:modelerTemplate="io.camunda.connectors.HttpJson.v2" zeebe:modelerTemplateVersion="13" zeebe:modelerTemplateIcon="data:image/svg+xml;base64,">
      <bpmn:extensionElements>
        <zeebe:taskDefinition type="io.camunda:http-json:1" retries="3" />
        <zeebe:ioMapping>
          <zeebe:input source="noAuth" target="authentication.type" />
          <zeebe:input source="GET" target="method" />
          <zeebe:input source="http://KONG_SERVER_PLACEHOLDER:8000/FlexibilityEvent/logs/20" target="url" />
          <zeebe:input source="=false" target="storeResponse" />
          <zeebe:input source="=false" target="followRedirects" />
          <zeebe:input source="=20" target="connectionTimeoutInSeconds" />
          <zeebe:input source="=20" target="readTimeoutInSeconds" />
        </zeebe:ioMapping>
        <zeebe:taskHeaders>
          <zeebe:header key="elementTemplateVersion" value="13" />
          <zeebe:header key="elementTemplateId" value="io.camunda.connectors.HttpJson.v2" />
          <zeebe:header key="resultExpression" value="={&#10;  flexibilityLogsStatus: response.status,&#10;  flexibilityLogs:       response.body,&#10;  hasflexibilityLogs: if (response.status = 200 and response.body != null and count(response.body) &#62; 0) then true else false&#10;}" />
          <zeebe:header key="retryBackoff" value="PT10S" />
        </zeebe:taskHeaders>
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_1y0y9l8</bpmn:incoming>
      <bpmn:outgoing>Flow_11byk07</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:exclusiveGateway id="Gateway_1wfxhep" name="Are there Flexibility&#10;Event Logs to analyse?">
      <bpmn:incoming>Flow_11byk07</bpmn:incoming>
      <bpmn:outgoing>Flow_1y0762k</bpmn:outgoing>
      <bpmn:outgoing>Flow_1mr6myg</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:sequenceFlow id="Flow_0a9e14a" sourceRef="Activity_1b1jk70" targetRef="Gateway_10xhc8a" />
    <bpmn:sequenceFlow id="Flow_07ktx5n" name="Yes" sourceRef="Gateway_10xhc8a" targetRef="Activity_1obo2qh">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">=promise = true</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="Flow_1y0y9l8" sourceRef="Activity_1obo2qh" targetRef="Task_FetchFlexibilityLogs" />
    <bpmn:sequenceFlow id="Flow_11byk07" sourceRef="Task_FetchFlexibilityLogs" targetRef="Gateway_1wfxhep" />
    <bpmn:sequenceFlow id="Flow_1mr6myg" name="Yes" sourceRef="Gateway_1wfxhep" targetRef="Activity_1fwp0r4">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">=hasflexibilityLogs = true</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:serviceTask id="Task_PersistForecastResult" name="Persist Flexibility Forecasting&#10;Result" zeebe:modelerTemplate="io.camunda.connectors.HttpJson.v2" zeebe:modelerTemplateVersion="13" zeebe:modelerTemplateIcon="data:image/svg+xml;base64,">
      <bpmn:extensionElements>
        <zeebe:taskDefinition type="io.camunda:http-json:1" retries="3" />
        <zeebe:ioMapping>
          <zeebe:input source="noAuth" target="authentication.type" />
          <zeebe:input source="POST" target="method" />
          <zeebe:input source="http://KONG_SERVER_PLACEHOLDER:8000/FlexibilityForecasting/forecast" target="url" />
          <zeebe:input source="={&#10;  &#34;Content-Type&#34;: &#34;Application/json&#34;,&#10;  &#34;accept&#34;: &#34;Application/json&#34;&#10;}" target="headers" />
          <zeebe:input source="=false" target="storeResponse" />
          <zeebe:input source="=false" target="followRedirects" />
          <zeebe:input source="=20" target="connectionTimeoutInSeconds" />
          <zeebe:input source="=20" target="readTimeoutInSeconds" />
          <zeebe:input source="={&#10;  &#34;successRate&#34;: aggregation.successRate,&#10;  &#34;dominantSentiment&#34;: aggregation.dominantSentiment,&#10;  &#34;totalEventsAnalyzed&#34;: aggregation.total,&#10;  &#34;analyzedEventIds&#34;: aggregation.analyzedEventIds&#10;}" target="body" />
        </zeebe:ioMapping>
        <zeebe:taskHeaders>
          <zeebe:header key="elementTemplateVersion" value="13" />
          <zeebe:header key="elementTemplateId" value="io.camunda.connectors.HttpJson.v2" />
          <zeebe:header key="resultExpression" value="={&#10;  persistStatus:       response.status,&#10;  forecastPersistedId: response.body.forecastId&#10;}" />
          <zeebe:header key="retryBackoff" value="PT10S" />
        </zeebe:taskHeaders>
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_1egou84</bpmn:incoming>
      <bpmn:outgoing>Flow_0eirjyg</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:endEvent id="EndEvent_ForecastComplete" name="Flexibility Forecasting Persisted">
      <bpmn:incoming>Flow_1rn6o3t</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:task id="Activity_0k6ynkp" name="Declare Flexibility Forecasting">
      <bpmn:incoming>Flow_0uztbdx</bpmn:incoming>
      <bpmn:outgoing>Flow_10xzvfo</bpmn:outgoing>
    </bpmn:task>
    <bpmn:userTask id="Activity_1gqsmnq" name="Check Flexibility Forecasting">
      <bpmn:extensionElements>
        <zeebe:userTask />
        <zeebe:assignmentDefinition assignee="demo" />
        <zeebe:formDefinition formId="Form_Check_FlexibilityForecasting" />
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_10xzvfo</bpmn:incoming>
      <bpmn:outgoing>Flow_1jcpkdo</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:exclusiveGateway id="Gateway_0xdan8i" name="Approved Flexibility Forecasting ?">
      <bpmn:incoming>Flow_1jcpkdo</bpmn:incoming>
      <bpmn:outgoing>Flow_0k33l05</bpmn:outgoing>
      <bpmn:outgoing>Flow_1dpg2l4</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:task id="Activity_08kjrab" name="Promise Flexibility Forecasting persistence">
      <bpmn:incoming>Flow_0k33l05</bpmn:incoming>
      <bpmn:outgoing>Flow_1egou84</bpmn:outgoing>
    </bpmn:task>
    <bpmn:endEvent id="Event_1akqo88" name="No Flexibility Forecasting Persisted">
      <bpmn:incoming>Flow_1dpg2l4</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:task id="Activity_1dvv2oq" name="Declare Flexibility Forecasting persistence">
      <bpmn:incoming>Flow_0eirjyg</bpmn:incoming>
      <bpmn:outgoing>Flow_1rn6o3t</bpmn:outgoing>
    </bpmn:task>
    <bpmn:subProcess id="Activity_1fwp0r4" name="AI Analysis">
      <bpmn:incoming>Flow_1mr6myg</bpmn:incoming>
      <bpmn:outgoing>Flow_1r9ygol</bpmn:outgoing>
      <bpmn:multiInstanceLoopCharacteristics isSequential="true">
        <bpmn:extensionElements>
          <zeebe:loopCharacteristics inputCollection="=flexibilityLogs" inputElement="event" outputCollection="eventResults" outputElement="={&#10;  eventId: event.id, &#10;  assetId: event.assetId, &#10;  ollamaRaw: ollamaRawText&#10;}" />
        </bpmn:extensionElements>
      </bpmn:multiInstanceLoopCharacteristics>
      <bpmn:startEvent id="Event_0hg4a4w">
        <bpmn:outgoing>Flow_18tnczm</bpmn:outgoing>
      </bpmn:startEvent>
      <bpmn:sequenceFlow id="Flow_18tnczm" sourceRef="Event_0hg4a4w" targetRef="Activity_1vly7vq" />
      <bpmn:serviceTask id="Task_BuildOllamaPrompt" name="Build Ollama&#10;Prompt" zeebe:modelerTemplate="io.camunda.connectors.HttpJson.v2" zeebe:modelerTemplateVersion="13" zeebe:modelerTemplateIcon="data:image/svg+xml;base64,">
        <bpmn:extensionElements>
          <zeebe:taskDefinition type="io.camunda:http-json:1" retries="3" />
          <zeebe:ioMapping>
            <zeebe:input source="noAuth" target="authentication.type" />
            <zeebe:input source="POST" target="method" />
            <zeebe:input source="http://KONG_SERVER_PLACEHOLDER:8000/FlexibilityForecasting/build-prompt" target="url" />
            <zeebe:input source="={&#10;  &#34;Content-Type&#34;: &#34;application/json&#34;,&#10;  &#34;accept&#34;: &#34;application/json&#34;&#10;}" target="headers" />
            <zeebe:input source="=false" target="storeResponse" />
            <zeebe:input source="=false" target="followRedirects" />
            <zeebe:input source="=20" target="connectionTimeoutInSeconds" />
            <zeebe:input source="=20" target="readTimeoutInSeconds" />
            <zeebe:input source="={&#10;  &#34;eventId&#34;: event.id,&#10;  &#34;assetId&#34;: event.assetId,&#10;  &#34;eventType&#34;: event.eventType,&#10;  &#34;recommendedAction&#34;: event.recommendedAction,&#10;  &#34;socAtEventTime&#34;: event.soc_percent,&#10;  &#34;sohAtEventTime&#34;: event.soh_percent,&#10;  &#34;marketPriceLevel&#34;: event.marketPriceLevel,&#10;  &#34;gridCellId&#34;: event.gridCellId,&#10;  &#34;currentSoc&#34;: telemetry.State_of_Charge,&#10;  &#34;currentOutputKw&#34;: telemetry.Current_Output,&#10;  &#34;currentStatus&#34;: telemetry.Status&#10;}" target="body" />
            <zeebe:input source="=false" target="ignoreNullValues" />
          </zeebe:ioMapping>
          <zeebe:taskHeaders>
            <zeebe:header key="elementTemplateVersion" value="13" />
            <zeebe:header key="elementTemplateId" value="io.camunda.connectors.HttpJson.v2" />
            <zeebe:header key="resultExpression" value="={&#10;  promptStatus: response.status,&#10;  prompt: response.body.prompt&#10;}" />
            <zeebe:header key="retryBackoff" value="PT0S" />
          </zeebe:taskHeaders>
        </bpmn:extensionElements>
        <bpmn:incoming>Flow_0gq6rja</bpmn:incoming>
        <bpmn:outgoing>Flow_18tgabh</bpmn:outgoing>
      </bpmn:serviceTask>
      <bpmn:serviceTask id="Task_CallOllama" name="Call Ollama llama3&#10;AI Analysis" zeebe:modelerTemplate="io.camunda.connectors.HttpJson.v2" zeebe:modelerTemplateVersion="13" zeebe:modelerTemplateIcon="data:image/svg+xml;base64,">
        <bpmn:extensionElements>
          <zeebe:taskDefinition type="io.camunda:http-json:1" retries="2" />
          <zeebe:ioMapping>
            <zeebe:input source="noAuth" target="authentication.type" />
            <zeebe:input source="POST" target="method" />
            <zeebe:input source="http://KONG_SERVER_PLACEHOLDER:8000/api/generate" target="url" />
            <zeebe:input source="={&#10;  &#34;Content-Type&#34;: &#34;Application/json&#34;,&#10;  &#34;accept&#34;: &#34;Application/json&#34;&#10;}" target="headers" />
            <zeebe:input source="=false" target="storeResponse" />
            <zeebe:input source="=false" target="followRedirects" />
            <zeebe:input source="=300" target="connectionTimeoutInSeconds" />
            <zeebe:input source="=300" target="readTimeoutInSeconds" />
            <zeebe:input source="={&#34;model&#34;: &#34;llama3.2&#34;, &#34;prompt&#34;: prompt, &#34;stream&#34;: false}" target="body" />
          </zeebe:ioMapping>
          <zeebe:taskHeaders>
            <zeebe:header key="elementTemplateVersion" value="13" />
            <zeebe:header key="elementTemplateId" value="io.camunda.connectors.HttpJson.v2" />
            <zeebe:header key="resultExpression" value="={&#10;  ollamaStatus:   response.status,&#10;  ollamaRawText: response.body.response,&#10;  ollamaDone:     response.body.done&#10;}" />
            <zeebe:header key="retryBackoff" value="PT15S" />
          </zeebe:taskHeaders>
        </bpmn:extensionElements>
        <bpmn:incoming>Flow_18tgabh</bpmn:incoming>
        <bpmn:outgoing>Flow_0mlv815</bpmn:outgoing>
      </bpmn:serviceTask>
      <bpmn:sequenceFlow id="Flow_0gq6rja" sourceRef="Activity_1vly7vq" targetRef="Task_BuildOllamaPrompt" />
      <bpmn:sequenceFlow id="Flow_18tgabh" sourceRef="Task_BuildOllamaPrompt" targetRef="Task_CallOllama" />
      <bpmn:endEvent id="Event_1evj151">
        <bpmn:incoming>Flow_0mlv815</bpmn:incoming>
      </bpmn:endEvent>
      <bpmn:sequenceFlow id="Flow_0mlv815" sourceRef="Task_CallOllama" targetRef="Event_1evj151" />
      <bpmn:serviceTask id="Activity_1vly7vq" name="Retrieve Latest Asset Telemetry" zeebe:modelerTemplate="io.camunda.connectors.HttpJson.v2" zeebe:modelerTemplateVersion="13" zeebe:modelerTemplateIcon="data:image/svg+xml;base64,">
        <bpmn:extensionElements>
          <zeebe:taskDefinition type="io.camunda:http-json:1" retries="3" />
          <zeebe:ioMapping>
            <zeebe:input source="noAuth" target="authentication.type" />
            <zeebe:input source="GET" target="method" />
            <zeebe:input source="=&#34;http://KONG_SERVER_PLACEHOLDER:8000/Telemetry/latest/&#34; + string(event.assetId)" target="url" />
            <zeebe:input source="=false" target="storeResponse" />
            <zeebe:input source="=false" target="followRedirects" />
            <zeebe:input source="=20" target="connectionTimeoutInSeconds" />
            <zeebe:input source="=20" target="readTimeoutInSeconds" />
          </zeebe:ioMapping>
          <zeebe:taskHeaders>
            <zeebe:header key="elementTemplateVersion" value="13" />
            <zeebe:header key="elementTemplateId" value="io.camunda.connectors.HttpJson.v2" />
            <zeebe:header key="resultExpression" value="={&#10;  telemetryStatus: response.status,&#10;  telemetry: response.body&#10;}" />
            <zeebe:header key="retryBackoff" value="PT0S" />
          </zeebe:taskHeaders>
        </bpmn:extensionElements>
        <bpmn:incoming>Flow_18tnczm</bpmn:incoming>
        <bpmn:outgoing>Flow_0gq6rja</bpmn:outgoing>
      </bpmn:serviceTask>
    </bpmn:subProcess>
    <bpmn:scriptTask id="Activity_10t6jow" name="Compute median Success Rate and Sentiment">
      <bpmn:extensionElements>
        <zeebe:script expression="={&#10;  total: count(eventResults),&#10;  successRate: if count(eventResults) &#62; 0&#10;               then (count(eventResults[contains(item.ollamaRaw, &#34;SUCCESS: YES&#34;)]) / count(eventResults)) * 100&#10;               else 0,&#10;  dominantSentiment: if count(eventResults[contains(item.ollamaRaw, &#34;SENTIMENT: POSITIVE&#34;)]) &#62;= count(eventResults[contains(item.ollamaRaw, &#34;SENTIMENT: NEGATIVE&#34;)])&#10;                     and count(eventResults[contains(item.ollamaRaw, &#34;SENTIMENT: POSITIVE&#34;)]) &#62;= count(eventResults[contains(item.ollamaRaw, &#34;SENTIMENT: NEUTRAL&#34;)])&#10;                     then &#34;POSITIVE&#34;&#10;                     else if count(eventResults[contains(item.ollamaRaw, &#34;SENTIMENT: NEGATIVE&#34;)]) &#62;= count(eventResults[contains(item.ollamaRaw, &#34;SENTIMENT: NEUTRAL&#34;)])&#10;                     then &#34;NEGATIVE&#34;&#10;                     else &#34;NEUTRAL&#34;,&#10;  analyzedEventIds: string join(for id in eventResults.eventId return string(id), &#34;,&#34;)&#10;}" resultVariable="aggregation" />
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_1r9ygol</bpmn:incoming>
      <bpmn:outgoing>Flow_0uztbdx</bpmn:outgoing>
    </bpmn:scriptTask>
    <bpmn:sequenceFlow id="Flow_1egou84" sourceRef="Activity_08kjrab" targetRef="Task_PersistForecastResult" />
    <bpmn:sequenceFlow id="Flow_0eirjyg" sourceRef="Task_PersistForecastResult" targetRef="Activity_1dvv2oq" />
    <bpmn:sequenceFlow id="Flow_1rn6o3t" sourceRef="Activity_1dvv2oq" targetRef="EndEvent_ForecastComplete" />
    <bpmn:sequenceFlow id="Flow_0uztbdx" sourceRef="Activity_10t6jow" targetRef="Activity_0k6ynkp" />
