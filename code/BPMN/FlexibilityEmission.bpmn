        <bpmn:flowNodeRef>GW_EventCreated</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Gateway_0f0zq2s</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Activity_1qq36t0</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Event_0f6sje0</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>EndEvent_NoRuleTriggered</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Event_0pes0qe</bpmn:flowNodeRef>
      </bpmn:lane>
      <bpmn:lane id="Lane_FlexibilityEvaluation" name="Flexibility Offer Evaluation">
        <bpmn:flowNodeRef>Task_EvaluateFlexibility</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>GW_HasTelemetry</bpmn:flowNodeRef>
