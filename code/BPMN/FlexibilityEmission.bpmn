<?xml version="1.0" encoding="UTF-8"?>
<bpmn:definitions xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL" xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:dc="http://www.omg.org/spec/DD/20100524/DC" xmlns:di="http://www.omg.org/spec/DD/20100524/DI" xmlns:bioc="http://bpmn.io/schema/bpmn/biocolor/1.0" xmlns:color="http://www.omg.org/spec/BPMN/non-normative/color/1.0" xmlns:zeebe="http://camunda.org/schema/zeebe/1.0" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xmlns:modeler="http://camunda.org/schema/modeler/1.0" id="Definitions_FlexibilityEmission" targetNamespace="http://bpmn.io/schema/bpmn" exporter="Camunda Modeler" exporterVersion="5.47.0" modeler:executionPlatform="Camunda Cloud" modeler:executionPlatformVersion="8.9.0">
  <bpmn:collaboration id="Collaboration_FlexibilityEmission">
    <bpmn:participant id="Participant_FlexibilityEmissionOrchestrator" name="FLEXIBILITY EMISSION" processRef="FlexibilityEmission" />
  </bpmn:collaboration>
  <bpmn:process id="FlexibilityEmission" name="FlexibilityEmission" isExecutable="true">
    <bpmn:laneSet id="LaneSet_FlexibilityEmission">
      <bpmn:lane id="Lane_FlexibilityEvaluation" name="Flexibility Offer Evaluation">
        <bpmn:flowNodeRef>GW_HasTelemetry</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_RetriveLatestTelemetry</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Activity_0rnx4e6</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_VerifyIfPossible</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Activity_0xp7pn3</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Gateway_0t0mnav</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Activity_1pmvp2o</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Activity_10bhmpn</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Activity_0xtbddh</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Activity_0hm77ej</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Activity_1mxk2j4</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Activity_0eko9jy</bpmn:flowNodeRef>
      </bpmn:lane>
      <bpmn:lane id="Lane_Flexibility_Manager" name="Flexibility Emission Manager">
        <bpmn:flowNodeRef>StartEvent_Timer</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_GetAllBatteryAssets</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_DecideEvaluation</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>GW_HasAssets</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>EndEvent_NoAssets</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Event_0xwp9jw</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>EndEvent_SkipNoTelemetry</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>GW_EventCreated</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Gateway_0f0zq2s</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Activity_1qq36t0</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Event_0pes0qe</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Activity_1s7akko</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Event_0f6sje0</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>EndEvent_NoRuleTriggered</bpmn:flowNodeRef>
      </bpmn:lane>
    </bpmn:laneSet>
    <bpmn:startEvent id="StartEvent_Timer" name="Every 10 Minutes">
      <bpmn:outgoing>Flow_Timer_To_GetAssets</bpmn:outgoing>
      <bpmn:timerEventDefinition id="TED_Timer">
        <bpmn:timeCycle xsi:type="bpmn:tFormalExpression">R/PT10M</bpmn:timeCycle>
      </bpmn:timerEventDefinition>
    </bpmn:startEvent>
    <bpmn:serviceTask id="Task_GetAllBatteryAssets" name="Retrive All Active Battery Assets" zeebe:modelerTemplate="io.camunda.connectors.HttpJson.v2" zeebe:modelerTemplateVersion="13" zeebe:modelerTemplateIcon="data:image/svg+xml;base64,">
      <bpmn:extensionElements>
        <zeebe:taskDefinition type="io.camunda:http-json:1" retries="3" />
        <zeebe:ioMapping>
          <zeebe:input source="noAuth" target="authentication.type" />
          <zeebe:input source="GET" target="method" />
          <zeebe:input source="http://KONG_SERVER_PLACEHOLDER:8000/Prosumer/assets/active/BATTERY" target="url" />
          <zeebe:input source="=false" target="storeResponse" />
          <zeebe:input source="=false" target="followRedirects" />
          <zeebe:input source="=20" target="connectionTimeoutInSeconds" />
          <zeebe:input source="=20" target="readTimeoutInSeconds" />
        </zeebe:ioMapping>
        <zeebe:taskHeaders>
          <zeebe:header key="elementTemplateVersion" value="13" />
          <zeebe:header key="elementTemplateId" value="io.camunda.connectors.HttpJson.v2" />
          <zeebe:header key="resultExpression" value="={&#10;  catalogStatus: response.status,&#10;  batteryAssetsList: response.body&#10;}" />
          <zeebe:header key="retryBackoff" value="PT10S" />
        </zeebe:taskHeaders>
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_Timer_To_GetAssets</bpmn:incoming>
      <bpmn:outgoing>Flow_0j8mzzu</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:userTask id="Task_DecideEvaluation" name="Decide if Flexibility Offers will be evaluated">
      <bpmn:extensionElements>
        <zeebe:userTask />
        <zeebe:assignmentDefinition assignee="demo" />
        <zeebe:formDefinition formId="Form_Decide_FlexibilityEvaluation" />
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_0j8mzzu</bpmn:incoming>
      <bpmn:outgoing>Flow_0ajuw7g</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:exclusiveGateway id="GW_HasAssets" name="Are Flexibility Emissions to be evaluated ?">
      <bpmn:incoming>Flow_0ajuw7g</bpmn:incoming>
      <bpmn:outgoing>Flow_HasAssets_No</bpmn:outgoing>
      <bpmn:outgoing>Flow_1336aml</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:endEvent id="EndEvent_NoAssets" name="No analysis of Flexibility Emissions">
      <bpmn:incoming>Flow_HasAssets_No</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:endEvent id="Event_0xwp9jw" name="Evaluation Not possible">
      <bpmn:incoming>Flow_08r6ey9</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:endEvent id="EndEvent_SkipNoTelemetry" name="No Telemetry&#10;Available">
      <bpmn:incoming>Flow_HasTelemetry_No</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:exclusiveGateway id="GW_EventCreated" name="Emit Flexibility Offers?">
      <bpmn:incoming>Flow_0m4gqlh</bpmn:incoming>
      <bpmn:outgoing>Flow_EventCreated_No</bpmn:outgoing>
      <bpmn:outgoing>Flow_EventCreated_Yes</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:exclusiveGateway id="Gateway_0f0zq2s" name="Flexibility Offers&#10;Suggested?">
      <bpmn:incoming>Flow_13y3gx1</bpmn:incoming>
      <bpmn:outgoing>Flow_1oqcgwt</bpmn:outgoing>
      <bpmn:outgoing>Flow_1o3jar3</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:userTask id="Activity_1qq36t0" name="Check Flexibility Offers">
      <bpmn:extensionElements>
        <zeebe:userTask />
        <zeebe:assignmentDefinition assignee="demo" />
        <zeebe:formDefinition formId="Form_Check_FlexibilityEmission" />
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_1o3jar3</bpmn:incoming>
      <bpmn:outgoing>Flow_0m4gqlh</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:endEvent id="Event_0pes0qe" name="No Flexibility Offers&#10;Suggested">
      <bpmn:incoming>Flow_1oqcgwt</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:serviceTask id="Activity_1s7akko" name="Publish Flexibility Offer" zeebe:modelerTemplate="io.camunda.connectors.KAFKA.v1" zeebe:modelerTemplateVersion="6" zeebe:modelerTemplateIcon="data:image/svg+xml;base64,">
      <bpmn:extensionElements>
        <zeebe:taskDefinition type="io.camunda:connector-kafka:1" retries="3" />
        <zeebe:ioMapping>
          <zeebe:input source="ec2-32-196-241-98.compute-1.amazonaws.com:9092" target="topic.bootstrapServers" />
          <zeebe:input source="Flexibility-Offers" target="topic.topicName" />
          <zeebe:input source="noSchema" target="schemaStrategy.type" />
          <zeebe:input source="=string(currentFlexibilityEvent.prosumerId)" target="message.key" />
          <zeebe:input source="=string(currentFlexibilityEvent)" target="message.value" />
        </zeebe:ioMapping>
        <zeebe:taskHeaders>
          <zeebe:header key="elementTemplateVersion" value="6" />
          <zeebe:header key="elementTemplateId" value="io.camunda.connectors.KAFKA.v1" />
          <zeebe:header key="retryBackoff" value="PT0S" />
        </zeebe:taskHeaders>
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_018zirq</bpmn:incoming>
      <bpmn:outgoing>Flow_17x4jzy</bpmn:outgoing>
      <bpmn:multiInstanceLoopCharacteristics>
        <bpmn:extensionElements>
          <zeebe:loopCharacteristics inputCollection="=FlexibilityEmissionList" inputElement="currentFlexibilityEvent" />
        </bpmn:extensionElements>
      </bpmn:multiInstanceLoopCharacteristics>
    </bpmn:serviceTask>
    <bpmn:endEvent id="Event_0f6sje0" name="Flexibility Offer Emitted">
      <bpmn:incoming>Flow_17x4jzy</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:endEvent id="EndEvent_NoRuleTriggered" name="No Flexibility Offer Emitted">
      <bpmn:incoming>Flow_EventCreated_No</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:sequenceFlow id="Flow_Timer_To_GetAssets" sourceRef="StartEvent_Timer" targetRef="Task_GetAllBatteryAssets" />
    <bpmn:sequenceFlow id="Flow_0j8mzzu" sourceRef="Task_GetAllBatteryAssets" targetRef="Task_DecideEvaluation" />
    <bpmn:sequenceFlow id="Flow_1336aml" name="Yes" sourceRef="GW_HasAssets" targetRef="Task_VerifyIfPossible">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">=decide = true</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="Flow_0ajuw7g" sourceRef="Task_DecideEvaluation" targetRef="GW_HasAssets" />
    <bpmn:sequenceFlow id="Flow_HasAssets_No" name="No" sourceRef="GW_HasAssets" targetRef="EndEvent_NoAssets">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">=decide = false</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="Flow_08r6ey9" name="No" sourceRef="Gateway_0t0mnav" targetRef="Event_0xwp9jw">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">=promise = false</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="Flow_HasTelemetry_No" name="No" sourceRef="GW_HasTelemetry" targetRef="EndEvent_SkipNoTelemetry">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">=hasTelemetry = false</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="Flow_13y3gx1" sourceRef="Activity_0xp7pn3" targetRef="Gateway_0f0zq2s" />
    <bpmn:sequenceFlow id="Flow_0m4gqlh" sourceRef="Activity_1qq36t0" targetRef="GW_EventCreated" />
    <bpmn:sequenceFlow id="Flow_EventCreated_Yes" name="Yes" sourceRef="GW_EventCreated" targetRef="Activity_0xtbddh">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">=emit = true</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="Flow_EventCreated_No" name="No" sourceRef="GW_EventCreated" targetRef="EndEvent_NoRuleTriggered">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">=emit = false</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="Flow_1oqcgwt" name="No" sourceRef="Gateway_0f0zq2s" targetRef="Event_0pes0qe">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">=count(FlexibilityEmissionList) = 0</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="Flow_1o3jar3" name="Yes" sourceRef="Gateway_0f0zq2s" targetRef="Activity_1qq36t0">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">=count(FlexibilityEmissionList) &gt; 0</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="Flow_018zirq" sourceRef="Activity_1pmvp2o" targetRef="Activity_1s7akko" />
    <bpmn:sequenceFlow id="Flow_17x4jzy" sourceRef="Activity_1s7akko" targetRef="Event_0f6sje0" />
    <bpmn:exclusiveGateway id="GW_HasTelemetry" name="Telemetry&#10;Reading Exists?">
      <bpmn:incoming>Flow_1go71bu</bpmn:incoming>
      <bpmn:outgoing>Flow_HasTelemetry_No</bpmn:outgoing>
      <bpmn:outgoing>Flow_0rqtn91</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:serviceTask id="Task_RetriveLatestTelemetry" name="Retrive Latest Battery Telemetry" zeebe:modelerTemplate="io.camunda.connectors.HttpJson.v2" zeebe:modelerTemplateVersion="13" zeebe:modelerTemplateIcon="data:image/svg+xml;base64,">
      <bpmn:extensionElements>
        <zeebe:taskDefinition type="io.camunda:http-json:1" retries="3" />
        <zeebe:ioMapping>
          <zeebe:input source="noAuth" target="authentication.type" />
          <zeebe:input source="GET" target="method" />
          <zeebe:input source="http://KONG_SERVER_PLACEHOLDER:8000/Telemetry/latest/BATTERY/10" target="url" />
          <zeebe:input source="=false" target="storeResponse" />
          <zeebe:input source="=false" target="followRedirects" />
          <zeebe:input source="=20" target="connectionTimeoutInSeconds" />
          <zeebe:input source="=20" target="readTimeoutInSeconds" />
        </zeebe:ioMapping>
        <zeebe:taskHeaders>
          <zeebe:header key="elementTemplateVersion" value="13" />
          <zeebe:header key="elementTemplateId" value="io.camunda.connectors.HttpJson.v2" />
          <zeebe:header key="resultExpression" value="={&#10;  telemetryStatus: response.status,&#10;  telemetryList: response.body,&#10;  hasTelemetry: if (response.status = 200 and response.body != null and count(response.body) &#62; 0) then true else false&#10;}" />
          <zeebe:header key="retryBackoff" value="PT5S" />
        </zeebe:taskHeaders>
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_1q0juq7</bpmn:incoming>
      <bpmn:outgoing>Flow_1go71bu</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:task id="Activity_0rnx4e6" name="Promise Flexibility Offers">
      <bpmn:incoming>Flow_1jfxnby</bpmn:incoming>
      <bpmn:outgoing>Flow_1q0juq7</bpmn:outgoing>
    </bpmn:task>
    <bpmn:userTask id="Task_VerifyIfPossible" name="Verify if execute Flexibility Offer is possible">
      <bpmn:extensionElements>
        <zeebe:userTask />
        <zeebe:assignmentDefinition assignee="demo" />
        <zeebe:formDefinition formId="Form_Promise_FlexibilityOffers" />
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_1336aml</bpmn:incoming>
      <bpmn:outgoing>Flow_10xavtw</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:task id="Activity_0xp7pn3" name="Declare Flexibility Offers">
      <bpmn:incoming>Flow_1fqj0q7</bpmn:incoming>
      <bpmn:outgoing>Flow_13y3gx1</bpmn:outgoing>
    </bpmn:task>
    <bpmn:exclusiveGateway id="Gateway_0t0mnav" name="Is Flexibility Offer possible?">
      <bpmn:incoming>Flow_10xavtw</bpmn:incoming>
      <bpmn:outgoing>Flow_08r6ey9</bpmn:outgoing>
      <bpmn:outgoing>Flow_1jfxnby</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:task id="Activity_1pmvp2o" name="Declare Flexibility Forecasting persistence">
      <bpmn:incoming>Flow_0348xry</bpmn:incoming>
      <bpmn:outgoing>Flow_018zirq</bpmn:outgoing>
    </bpmn:task>
    <bpmn:serviceTask id="Activity_10bhmpn" name="Persist Flexibility Offers" zeebe:modelerTemplate="io.camunda.connectors.HttpJson.v2" zeebe:modelerTemplateVersion="13" zeebe:modelerTemplateIcon="data:image/svg+xml;base64,">
      <bpmn:extensionElements>
        <zeebe:taskDefinition type="io.camunda:http-json:1" retries="3" />
        <zeebe:ioMapping>
          <zeebe:input source="noAuth" target="authentication.type" />
          <zeebe:input source="POST" target="method" />
          <zeebe:input source="http://KONG_SERVER_PLACEHOLDER:8000/FlexibilityEvent/save" target="url" />
          <zeebe:input source="={&#10;  &#34;Content-Type&#34;: &#34;Application/json&#34;,&#10;  &#34;accept&#34;: &#34;Application/json&#34;&#10;}" target="headers" />
          <zeebe:input source="=false" target="storeResponse" />
          <zeebe:input source="=false" target="followRedirects" />
          <zeebe:input source="=20" target="connectionTimeoutInSeconds" />
          <zeebe:input source="=20" target="readTimeoutInSeconds" />
          <zeebe:input source="={&#34;eventCreated&#34;: FlexibilityEmissionList}" target="body" />
          <zeebe:input source="=false" target="ignoreNullValues" />
        </zeebe:ioMapping>
        <zeebe:taskHeaders>
          <zeebe:header key="elementTemplateVersion" value="13" />
          <zeebe:header key="elementTemplateId" value="io.camunda.connectors.HttpJson.v2" />
          <zeebe:header key="resultExpression" value="={&#10;  emissionStatus: response.status,&#10;  myResponseBody: response.body&#10;}" />
          <zeebe:header key="retryBackoff" value="PT0S" />
        </zeebe:taskHeaders>
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_0p0cpro</bpmn:incoming>
      <bpmn:outgoing>Flow_0348xry</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:task id="Activity_0xtbddh" name="Promise Flexibility Forecasting persistence">
      <bpmn:incoming>Flow_EventCreated_Yes</bpmn:incoming>
      <bpmn:outgoing>Flow_0p0cpro</bpmn:outgoing>
    </bpmn:task>
    <bpmn:businessRuleTask id="Activity_0hm77ej" name="Flexibility Offer Decision">
      <bpmn:extensionElements>
        <zeebe:calledDecision decisionId="Decision_FlexibilityOffer" resultVariable="dmnResult" />
        <zeebe:ioMapping>
          <zeebe:input source="=currentTelemetry.State_of_Charge" target="soc_percent" />
          <zeebe:input source="=currentTelemetry.State_of_Health" target="soh_percent" />
          <zeebe:input source="=marketPriceLevel" target="marketPriceLevel" />
          <zeebe:output source="={ &#10;assetId: currentTelemetry.asset_id, &#10;prosumerId: (batteryAssetsList[assetId = currentTelemetry.asset_id].prosumerId)[1], &#10;eventType: dmnResult.eventType,&#10;recommendedAction: dmnResult.recommendedAction,&#10;soc_percent: currentTelemetry.State_of_Charge,&#10;soh_percent: currentTelemetry.State_of_Health,&#10;marketPrice: marketPriceLevel, &#10;gridCellId: currentTelemetry.grid_cell_id &#10;}" target="currentEvent" />
        </zeebe:ioMapping>
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_1m8fiaq</bpmn:incoming>
      <bpmn:outgoing>Flow_14152q1</bpmn:outgoing>
      <bpmn:multiInstanceLoopCharacteristics>
        <bpmn:extensionElements>
          <zeebe:loopCharacteristics inputCollection="=telemetryList" inputElement="currentTelemetry" outputCollection="evaluatedEvents" outputElement="=currentEvent" />
        </bpmn:extensionElements>
      </bpmn:multiInstanceLoopCharacteristics>
    </bpmn:businessRuleTask>
    <bpmn:scriptTask id="Activity_1mxk2j4" name="Filter out &#34;NO_ACTION&#34; Events">
      <bpmn:extensionElements>
        <zeebe:script expression="=evaluatedEvents[eventType != &#34;NO_ACTION&#34;]" resultVariable="FlexibilityEmissionList" />
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_14152q1</bpmn:incoming>
      <bpmn:outgoing>Flow_1fqj0q7</bpmn:outgoing>
    </bpmn:scriptTask>
    <bpmn:userTask id="Activity_0eko9jy" name="Assess Market Price Level">
      <bpmn:extensionElements>
        <zeebe:userTask />
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_0rqtn91</bpmn:incoming>
      <bpmn:outgoing>Flow_1m8fiaq</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:sequenceFlow id="Flow_1go71bu" sourceRef="Task_RetriveLatestTelemetry" targetRef="GW_HasTelemetry" />
    <bpmn:sequenceFlow id="Flow_0rqtn91" name="Yes" sourceRef="GW_HasTelemetry" targetRef="Activity_0eko9jy" />
    <bpmn:sequenceFlow id="Flow_1q0juq7" sourceRef="Activity_0rnx4e6" targetRef="Task_RetriveLatestTelemetry" />
    <bpmn:sequenceFlow id="Flow_1jfxnby" name="Yes" sourceRef="Gateway_0t0mnav" targetRef="Activity_0rnx4e6">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">=promise = true</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="Flow_10xavtw" sourceRef="Task_VerifyIfPossible" targetRef="Gateway_0t0mnav" />
    <bpmn:sequenceFlow id="Flow_1fqj0q7" sourceRef="Activity_1mxk2j4" targetRef="Activity_0xp7pn3" />
    <bpmn:sequenceFlow id="Flow_0348xry" sourceRef="Activity_10bhmpn" targetRef="Activity_1pmvp2o" />
    <bpmn:sequenceFlow id="Flow_0p0cpro" sourceRef="Activity_0xtbddh" targetRef="Activity_10bhmpn" />
    <bpmn:sequenceFlow id="Flow_1m8fiaq" sourceRef="Activity_0eko9jy" targetRef="Activity_0hm77ej" />
    <bpmn:sequenceFlow id="Flow_14152q1" sourceRef="Activity_0hm77ej" targetRef="Activity_1mxk2j4" />
  </bpmn:process>
  <bpmndi:BPMNDiagram id="BPMNDiagram_FlexibilityEmission">
    <bpmndi:BPMNPlane id="BPMNPlane_FlexibilityEmission" bpmnElement="Collaboration_FlexibilityEmission">
      <bpmndi:BPMNShape id="Participant_FlexibilityEmissionOrchestrator_di" bpmnElement="Participant_FlexibilityEmissionOrchestrator" isHorizontal="true">
        <dc:Bounds x="160" y="80" width="1830" height="340" />
        <bpmndi:BPMNLabel />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Lane_AssetEvaluation_di" bpmnElement="Lane_FlexibilityEvaluation" isHorizontal="true">
        <dc:Bounds x="190" y="260" width="1800" height="160" />
        <bpmndi:BPMNLabel />
      </bpmndi:BPMNShape>
