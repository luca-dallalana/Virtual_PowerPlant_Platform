      <bpmn:incoming>Flow_1336aml</bpmn:incoming>
      <bpmn:outgoing>Flow_10xavtw</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:task id="Activity_0xp7pn3" name="Declare Flexibility Offers">
      <bpmn:incoming>Flow_0e0669x</bpmn:incoming>
      <bpmn:outgoing>Flow_13y3gx1</bpmn:outgoing>
    </bpmn:task>
    <bpmn:exclusiveGateway id="Gateway_0t0mnav" name="Is Flexibility Offer possible?">
      <bpmn:incoming>Flow_10xavtw</bpmn:incoming>
      <bpmn:outgoing>Flow_08r6ey9</bpmn:outgoing>
      <bpmn:outgoing>Flow_1jfxnby</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:sequenceFlow id="Flow_HasTelemetry_Yes" name="Yes" sourceRef="GW_HasTelemetry" targetRef="Task_EvaluateFlexibility">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">=hasTelemetry = true</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="Flow_0e0669x" sourceRef="Task_EvaluateFlexibility" targetRef="Activity_0xp7pn3" />
    <bpmn:sequenceFlow id="Flow_FetchTelemetry_To_HasTelemetry" sourceRef="Task_RetriveLatestTelemetry" targetRef="GW_HasTelemetry" />
    <bpmn:sequenceFlow id="Flow_103sqnj" sourceRef="Activity_0rnx4e6" targetRef="Task_RetriveLatestTelemetry" />
    <bpmn:sequenceFlow id="Flow_1jfxnby" name="Yes" sourceRef="Gateway_0t0mnav" targetRef="Activity_0rnx4e6">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">=promise = true</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="Flow_10xavtw" sourceRef="Task_VerifyIfPossible" targetRef="Gateway_0t0mnav" />
    <bpmn:exclusiveGateway id="GW_EventCreated" name="Emit Flexibility Offers?">
      <bpmn:incoming>Flow_0m4gqlh</bpmn:incoming>
      <bpmn:outgoing>Flow_EventCreated_No</bpmn:outgoing>
      <bpmn:outgoing>Flow_EventCreated_Yes</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:sequenceFlow id="Flow_EventCreated_Yes" name="Yes" sourceRef="GW_EventCreated" targetRef="Activity_0xtbddh">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">=emit = true</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="Flow_0p0cpro" sourceRef="Activity_0xtbddh" targetRef="Activity_10bhmpn" />
    <bpmn:sequenceFlow id="Flow_0348xry" sourceRef="Activity_10bhmpn" targetRef="Activity_1pmvp2o" />
    <bpmn:sequenceFlow id="Flow_02a8dzj" sourceRef="Activity_1pmvp2o" targetRef="Event_0f6sje0" />
    <bpmn:sequenceFlow id="Flow_EventCreated_No" name="No" sourceRef="GW_EventCreated" targetRef="EndEvent_NoRuleTriggered">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">=emit = false</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="Flow_13y3gx1" sourceRef="Activity_0xp7pn3" targetRef="Gateway_0f0zq2s" />
    <bpmn:sequenceFlow id="Flow_1oqcgwt" name="No" sourceRef="Gateway_0f0zq2s" targetRef="Event_0pes0qe">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">=hasFlexibilityEmission = false</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="Flow_1o3jar3" name="Yes" sourceRef="Gateway_0f0zq2s" targetRef="Activity_1qq36t0">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">=hasFlexibilityEmission = true</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:exclusiveGateway id="Gateway_0f0zq2s" name="Flexibility Offers&#10;Suggested?">
      <bpmn:incoming>Flow_13y3gx1</bpmn:incoming>
      <bpmn:outgoing>Flow_1oqcgwt</bpmn:outgoing>
      <bpmn:outgoing>Flow_1o3jar3</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:userTask id="Activity_1qq36t0" name="Check Flexibility Offers">
      <bpmn:extensionElements>
        <zeebe:userTask />
        <zeebe:formDefinition formId="Form_Check_FlexibilityEmission" />
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_1o3jar3</bpmn:incoming>
