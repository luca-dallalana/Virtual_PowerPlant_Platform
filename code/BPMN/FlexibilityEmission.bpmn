    <bpmn:startEvent id="StartEvent_Timer" name="Every 10 Minutes">
      <bpmn:outgoing>Flow_Timer_To_GetAssets</bpmn:outgoing>
      <bpmn:timerEventDefinition id="TED_Timer">
        <bpmn:timeCycle xsi:type="bpmn:tFormalExpression">R/PT10M</bpmn:timeCycle>
      </bpmn:timerEventDefinition>
    </bpmn:startEvent>
    <bpmn:serviceTask id="Task_GetAllBatteryAssets" name="Retrive All Battery Assets" zeebe:modelerTemplate="io.camunda.connectors.HttpJson.v2" zeebe:modelerTemplateVersion="13" zeebe:modelerTemplateIcon="data:image/svg+xml;base64,">
      <bpmn:extensionElements>
        <zeebe:taskDefinition type="io.camunda:http-json:1" retries="3" />
        <zeebe:ioMapping>
          <zeebe:input source="noAuth" target="authentication.type" />
          <zeebe:input source="GET" target="method" />
          <zeebe:input source="http://ec2-34-238-164-142.compute-1.amazonaws.com:8080/Prosumer/AssetBatteries" target="url" />
          <zeebe:input source="=false" target="storeResponse" />
          <zeebe:input source="=false" target="followRedirects" />
          <zeebe:input source="=20" target="connectionTimeoutInSeconds" />
          <zeebe:input source="=20" target="readTimeoutInSeconds" />
        </zeebe:ioMapping>
        <zeebe:taskHeaders>
          <zeebe:header key="elementTemplateVersion" value="13" />
          <zeebe:header key="elementTemplateId" value="io.camunda.connectors.HttpJson.v2" />
          <zeebe:header key="resultExpression" value="={&#10;  catalogStatus: response.status,&#10;  ProsumerbatteryAssetsMap: response.body&#10;}" />
          <zeebe:header key="retryBackoff" value="PT10S" />
        </zeebe:taskHeaders>
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_Timer_To_GetAssets</bpmn:incoming>
      <bpmn:outgoing>Flow_0j8mzzu</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:exclusiveGateway id="GW_HasAssets" name="Are Flexibility Emissions to be evaluated ?">
      <bpmn:incoming>Flow_0ajuw7g</bpmn:incoming>
      <bpmn:outgoing>Flow_HasAssets_No</bpmn:outgoing>
      <bpmn:outgoing>Flow_1336aml</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:userTask id="Task_DecideEvaluation" name="Decide if Flexibility Offers will be evaluated">
      <bpmn:extensionElements>
        <zeebe:userTask />
        <zeebe:assignmentDefinition assignee="Demo" />
        <zeebe:formDefinition formId="Form_Decide_FlexibilityEvaluation" />
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_0j8mzzu</bpmn:incoming>
      <bpmn:outgoing>Flow_0ajuw7g</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:sequenceFlow id="Flow_1336aml" name="Yes" sourceRef="GW_HasAssets" targetRef="Task_VerifyIfPossible">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">=decide = true</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="Flow_08r6ey9" name="No" sourceRef="Gateway_0t0mnav" targetRef="Event_0xwp9jw">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">=promise = false</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="Flow_HasTelemetry_No" name="No" sourceRef="GW_HasTelemetry" targetRef="EndEvent_SkipNoTelemetry">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">=hasTelemetry = false</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="Flow_Timer_To_GetAssets" sourceRef="StartEvent_Timer" targetRef="Task_GetAllBatteryAssets" />
    <bpmn:sequenceFlow id="Flow_0j8mzzu" sourceRef="Task_GetAllBatteryAssets" targetRef="Task_DecideEvaluation" />
    <bpmn:sequenceFlow id="Flow_0ajuw7g" sourceRef="Task_DecideEvaluation" targetRef="GW_HasAssets" />
    <bpmn:sequenceFlow id="Flow_HasAssets_No" name="No" sourceRef="GW_HasAssets" targetRef="EndEvent_NoAssets">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">=decide = false</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="Flow_0m4gqlh" sourceRef="Activity_1qq36t0" targetRef="GW_EventCreated" />
    <bpmn:endEvent id="EndEvent_SkipNoTelemetry" name="No Telemetry&#10;Available">
      <bpmn:incoming>Flow_HasTelemetry_No</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:endEvent id="EndEvent_NoAssets" name="No analysis of Flexibility Emissions">
      <bpmn:incoming>Flow_HasAssets_No</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:endEvent id="Event_0xwp9jw" name="Evaluation Not posible">
      <bpmn:incoming>Flow_08r6ey9</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:serviceTask id="Task_EvaluateFlexibility" name="Evaluate Flexibility Offers" zeebe:modelerTemplate="io.camunda.connectors.HttpJson.v2" zeebe:modelerTemplateVersion="13" zeebe:modelerTemplateIcon="data:image/svg+xml;base64,">
      <bpmn:extensionElements>
        <zeebe:taskDefinition type="io.camunda:http-json:1" retries="3" />
        <zeebe:ioMapping>
          <zeebe:input source="noAuth" target="authentication.type" />
          <zeebe:input source="POST" target="method" />
          <zeebe:input source="http://ec2-34-238-164-142.compute-1.amazonaws.com:8080/FlexibilityEvent/evaluate" target="url" />
          <zeebe:input source="={&#10;  &#34;Content-Type&#34;: &#34;Application/json&#34;,&#10;  &#34;accept&#34;: &#34;Application/json&#34;&#10;}" target="headers" />
          <zeebe:input source="=false" target="storeResponse" />
          <zeebe:input source="=false" target="followRedirects" />
          <zeebe:input source="=20" target="connectionTimeoutInSeconds" />
          <zeebe:input source="=20" target="readTimeoutInSeconds" />
          <zeebe:input source="=telemetryList" target="body" />
          <zeebe:input source="=false" target="ignoreNullValues" />
        </zeebe:ioMapping>
        <zeebe:taskHeaders>
          <zeebe:header key="elementTemplateVersion" value="13" />
          <zeebe:header key="elementTemplateId" value="io.camunda.connectors.HttpJson.v2" />
          <zeebe:header key="resultExpression" value="={&#10;  evaluationStatus: response.status,&#10;  FlexibilityEmissionList: response.body.eventCreated,&#10;  hasFlexibilityEmission: if (response.status = 200 and response.body != null) then true else false&#10;}" />
          <zeebe:header key="retryBackoff" value="PT5S" />
        </zeebe:taskHeaders>
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_HasTelemetry_Yes</bpmn:incoming>
      <bpmn:outgoing>Flow_0e0669x</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:exclusiveGateway id="GW_HasTelemetry" name="Telemetry&#10;Reading Exists?">
      <bpmn:incoming>Flow_FetchTelemetry_To_HasTelemetry</bpmn:incoming>
      <bpmn:outgoing>Flow_HasTelemetry_No</bpmn:outgoing>
      <bpmn:outgoing>Flow_HasTelemetry_Yes</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:serviceTask id="Task_RetriveLatestTelemetry" name="Retrive Latest Battery Telemetry" zeebe:modelerTemplate="io.camunda.connectors.HttpJson.v2" zeebe:modelerTemplateVersion="13" zeebe:modelerTemplateIcon="data:image/svg+xml;base64,">
      <bpmn:extensionElements>
        <zeebe:taskDefinition type="io.camunda:http-json:1" retries="3" />
        <zeebe:ioMapping>
          <zeebe:input source="noAuth" target="authentication.type" />
          <zeebe:input source="GET" target="method" />
          <zeebe:input source="=&#34;http://ec2-23-22-152-18.compute-1.amazonaws.com:8080/Telemetry/latest/&#34; + string(currentAsset.id)" target="url" />
          <zeebe:input source="=false" target="storeResponse" />
          <zeebe:input source="=false" target="followRedirects" />
          <zeebe:input source="=20" target="connectionTimeoutInSeconds" />
          <zeebe:input source="=20" target="readTimeoutInSeconds" />
        </zeebe:ioMapping>
        <zeebe:taskHeaders>
          <zeebe:header key="elementTemplateVersion" value="13" />
          <zeebe:header key="elementTemplateId" value="io.camunda.connectors.HttpJson.v2" />
          <zeebe:header key="resultExpression" value="={&#10;  telemetryStatus: response.status,&#10;  telemetryList: response.body,&#10;  hasTelemetry: if (response.status = 200 and response.body != null) then true else false&#10;}" />
          <zeebe:header key="retryBackoff" value="PT5S" />
        </zeebe:taskHeaders>
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_103sqnj</bpmn:incoming>
      <bpmn:outgoing>Flow_FetchTelemetry_To_HasTelemetry</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:task id="Activity_0rnx4e6" name="Promise Flexibility Offers">
      <bpmn:incoming>Flow_1jfxnby</bpmn:incoming>
      <bpmn:outgoing>Flow_103sqnj</bpmn:outgoing>
    </bpmn:task>
    <bpmn:userTask id="Task_VerifyIfPossible" name="Verify if execute Flexibility Offer is possible">
      <bpmn:extensionElements>
        <zeebe:userTask />
        <zeebe:formDefinition formId="Form_Promise_FlexibilityOffers" />
