      <output id="OutputClause_1g0xwdw" label="Recommended Action" name="recommendedAction" typeRef="string" />
      <rule id="DecisionRule_0uzpoly">
        <inputEntry id="UnaryTests_0mqywag">
          <text></text>
        </inputEntry>
        <inputEntry id="UnaryTests_1ttxgmm">
          <text></text>
        </inputEntry>
        <inputEntry id="UnaryTests_101ruk1">
          <text>&lt;= 20</text>
