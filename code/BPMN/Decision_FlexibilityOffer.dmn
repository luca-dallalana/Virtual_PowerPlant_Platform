          <text>&gt;= 70</text>
        </inputEntry>
        <inputEntry id="UnaryTests_0yyrwba">
          <text>"HIGH"</text>
        </inputEntry>
        <inputEntry id="UnaryTests_1qo32fp">
          <text>&gt;= 90</text>
        </inputEntry>
        <outputEntry id="LiteralExpression_1ye8ab4">
          <text>"ARBITRAGE_SELL"</text>
        </outputEntry>
        <outputEntry id="LiteralExpression_0jtc6p5">
