        "columns": null
      },
      "id": "Field_1m2sjaf",
      "key": "selectedEmit",
      "valuesExpression": "=for m in selectedMetrics return\n  if m = \"Generated Energy\" then { label: \"Generated Energy by Prosumer\", value: \"Generated Energy\" }\n  else if m = \"Consumed Energy\" then { label: \"Consumed Energy by Prosumer\", value: \"Consumed Energy\" }\n  else if m = \"Energy Discharged\" then { label: \"Energy Discharged by Zone\", value: \"Energy Discharged\" }\n  else { label: \"Average SoC\", value: \"Average SoC\" }"
    }
  ],
  "type": "default",
